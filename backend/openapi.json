    "/api/upload-fast": {
      "post": {
        "summary": "Process Upload Fast",
        "description": "Upload + extract audio.mp3 ONLY \u2014 no Sarvam STT, no diarization.\n\nUsed by the Gemini per-segment dub flow: Gemini transcribes/diarizes the\naudio itself during synthesis, so paying Sarvam for the same work is\nwasteful and slow. This endpoint just lands the file + audio.mp3 in the\nsession dir and returns the session_id, ready for /api/synthesize with\nsynthesis_mode='single_per_segment_gemini'.",
        "operationId": "process_upload_fast_api_upload_fast_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_process_upload_fast_api_upload_fast_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
