    "/api/dub-direct/start": {
      "post": {
        "summary": "Dub Direct Start",
        "description": "Start an end-to-end ElevenLabs dubbing job.\nSaves the uploaded file to a new session directory, submits to ElevenLabs,\nand returns session_id + dubbing_id immediately for the client to poll.",
        "operationId": "dub_direct_start_api_dub_direct_start_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
